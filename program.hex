// Addr 00: addi x1, x0, 10      | I-Type: x1 = 10
00A00093 
// Addr 04: addi x2, x0, 20      | I-Type: x2 = 20
01400113 
// Addr 08: add  x3, x1, x2      | R-Type: x3 = 10 + 20 = 30 (0x1E)
002081B3 
// Addr 0C: sub  x4, x2, x1      | R-Type: x4 = 20 - 10 = 10 (0x0A)
40110233 
// Addr 10: slli x5, x1, 2       | I-Shift: x5 = 10 << 2 = 40 (0x28)
00209293 
// Addr 14: beq  x1, x1, 8       | SB-Type: If 10==10, skip to Addr 1C
00108463 
// Addr 18: addi x3, x0, 0       | SHOULD BE SKIPPED
00000193 
// Addr 1C: jalr x6, 0(x2)       | JALR: Jump to 20 (0x14), x6 = 1C+4
00010367 

